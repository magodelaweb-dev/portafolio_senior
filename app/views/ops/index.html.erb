<% content_for :title, "Operaciones · Arturo Martinez" %>

<section class="mb-8 flex flex-wrap items-end justify-between gap-4">
  <div>
    <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-teal-600 dark:text-teal-400">Panel de Monitoreo</p>
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Panel de operaciones</h1>
    <p class="mt-2 max-w-2xl text-slate-600 dark:text-slate-400">
      Telemetría en tiempo real: latencia de peticiones, consumo de bases de datos SQLite y estado de
      procesos en segundo plano (<strong>Solid Queue</strong>). Actualización dinámica optimizada mediante Turbo y Stimulus.
    </p>
    <p class="mt-3 max-w-2xl text-sm text-slate-500">
      Lo que estás viendo no es una maqueta: es la telemetría real de la aplicación que te está
      sirviendo esta página. Operar en producción con observabilidad —no solo escribir código— es
      parte de lo que este portafolio quiere demostrar.
    </p>
  </div>
  <% if authenticated? %>
    <%= button_to "Encolar job de demo", ops_enqueue_path,
          class: "shrink-0 rounded-lg bg-teal-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-teal-500 cursor-pointer" %>
  <% end %>
</section>

<% if notice.present? %>
  <p class="mb-6 inline-block rounded-md bg-emerald-50 px-3 py-2 font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-300"><%= notice %></p>
<% end %>

<%= turbo_frame_tag "ops_metrics", src: ops_metrics_path,
      data: { controller: "poll", poll_interval_value: 3000 } do %>
  <div class="grid place-items-center rounded-2xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 py-20 text-slate-400">
    Cargando métricas…
  </div>
<% end %>
