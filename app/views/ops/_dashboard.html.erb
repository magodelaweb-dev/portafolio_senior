<div class="space-y-8">
  <div class="flex items-center justify-between text-xs text-slate-400">
    <span class="inline-flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      Monitoreando
    </span>
    <span>Actualizado a las <%= metrics[:generated_at].strftime("%H:%M:%S") %></span>
  </div>

  <%# ---- Señales doradas: latencia, tráfico, errores, saturación ---- %>
  <% req = metrics[:requests] %>
  <% backlog = metrics[:queue][:available] ? metrics[:queue][:ready] + metrics[:queue][:scheduled] : nil %>
  <% memory = metrics[:app][:memory_mb] %>
  <section>
    <h2 class="mb-1 text-sm font-semibold uppercase tracking-widest text-slate-500">Señales doradas</h2>
    <p class="mb-4 text-xs text-slate-400">
      Las cuatro señales que el SRE de Google recomienda vigilar en cualquier servicio: latencia, tráfico, errores y saturación.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 p-5">
        <div class="flex items-center justify-between">
          <p class="text-xs uppercase tracking-wide text-slate-400">Latencia</p>
          <%= ops_signal_badge(ops_signal_level(:latency, req[:count].zero? ? nil : req[:p95])) %>
        </div>
        <p class="mt-2 text-3xl font-bold text-slate-900 dark:text-slate-100"><%= req[:p95] %><span class="text-sm font-normal text-slate-400"> ms p95</span></p>
        <p class="mt-1 text-xs text-slate-500">95% de las peticiones respondió más rápido que esto. &lt; 200 ms es saludable aquí.</p>
        <% if req[:history].size > 1 %>
          <svg viewBox="0 0 240 40" class="mt-3 h-10 w-full text-teal-500 dark:text-teal-400" preserveAspectRatio="none" aria-hidden="true">
            <polyline points="<%= ops_sparkline_points(req[:history]) %>" fill="none" stroke="currentColor" stroke-width="1.5" />
          </svg>
        <% end %>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 p-5">
        <p class="text-xs uppercase tracking-wide text-slate-400">Tráfico</p>
        <p class="mt-2 text-3xl font-bold text-slate-900 dark:text-slate-100"><%= req[:rpm] %><span class="text-sm font-normal text-slate-400"> req/min</span></p>
        <p class="mt-1 text-xs text-slate-500">
          Peticiones en los últimos 60 s (el propio panel se excluye del muestreo).
          Ventana total: <%= req[:count] %> muestras.
        </p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 p-5">
        <div class="flex items-center justify-between">
          <p class="text-xs uppercase tracking-wide text-slate-400">Errores</p>
          <%= ops_signal_badge(ops_signal_level(:errors, req[:count].zero? ? nil : req[:error_rate])) %>
        </div>
        <p class="mt-2 text-3xl font-bold text-slate-900 dark:text-slate-100"><%= req[:error_rate] %><span class="text-sm font-normal text-slate-400"> % 5xx</span></p>
        <p class="mt-1 text-xs text-slate-500">
          <%= req[:server_errors] %> errores de servidor y <%= req[:client_errors] %> respuestas 4xx en la ventana.
        </p>
      </div>

      <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 p-5">
        <div class="flex items-center justify-between">
          <p class="text-xs uppercase tracking-wide text-slate-400">Saturación</p>
          <%= ops_signal_badge([ ops_signal_level(:memory, memory), ops_signal_level(:backlog, backlog) ].max_by { |l| [ :none, :ok, :warn, :crit ].index(l) }) %>
        </div>
        <p class="mt-2 text-3xl font-bold text-slate-900 dark:text-slate-100"><%= memory || "n/d" %><span class="text-sm font-normal text-slate-400"> MB RSS</span></p>
        <p class="mt-1 text-xs text-slate-500">
          Memoria residente del proceso. Cola en espera: <%= backlog || "n/d" %> jobs.
        </p>
      </div>
    </div>
  </section>

  <%# ---- Detalle de peticiones ---- %>
  <section>
    <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Detalle de peticiones recientes</h2>
      <p class="text-xs text-slate-400">
        Media <%= req[:avg] %> ms · Máx <%= req[:max] %> ms · BD promedio <%= req[:avg_db] %> ms
      </p>
    </div>
    <% if req[:recent].any? %>
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wide text-slate-400">
            <tr>
              <th class="px-4 py-2 font-medium">Endpoint</th>
              <th class="px-4 py-2 font-medium">Estado</th>
              <th class="px-4 py-2 font-medium text-right">Duración</th>
              <th class="px-4 py-2 font-medium text-right">BD</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            <% req[:recent].each do |s| %>
              <tr>
                <td class="px-4 py-2 font-mono text-xs text-slate-700 dark:text-slate-300"><%= s.controller %>#<%= s.action %></td>
                <td class="px-4 py-2">
                  <span class="rounded px-1.5 py-0.5 text-xs font-semibold <%= s.status.to_i < 400 ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300" : "bg-red-100 text-red-700 dark:bg-red-500/15 dark:text-red-300" %>"><%= s.status %></span>
                </td>
                <td class="px-4 py-2 text-right font-mono text-xs text-slate-700 dark:text-slate-300"><%= s.duration %> ms</td>
                <td class="px-4 py-2 text-right font-mono text-xs text-slate-500"><%= s.db_runtime %> ms</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="rounded-xl border border-dashed border-slate-300 p-6 text-center text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
        Aún no hay muestras: navega por el sitio en otra pestaña y vuelve.
      </p>
    <% end %>
  </section>

  <%# ---- Solid Queue ---- %>
  <section>
    <h2 class="mb-1 text-sm font-semibold uppercase tracking-widest text-slate-500">Trabajos en segundo plano · Solid Queue</h2>
    <p class="mb-3 text-xs text-slate-400">
      Cola de jobs persistida en SQLite, sin Redis. Los fallidos se conservan para inspección.
    </p>
    <% q = metrics[:queue] %>
    <% if q[:available] %>
      <div class="grid grid-cols-3 gap-4 sm:grid-cols-6">
        <% [
             [ "Listos", q[:ready], "text-sky-700 dark:text-sky-400" ],
             [ "Programados", q[:scheduled], "text-amber-700 dark:text-amber-400" ],
             [ "En curso", q[:in_progress], "text-teal-700 dark:text-teal-400" ],
             [ "Fallidos", q[:failed], "text-red-700 dark:text-red-400" ],
             [ "Finalizados", q[:finished], "text-emerald-700 dark:text-emerald-400" ],
             [ "Procesos", q[:processes], "text-slate-700 dark:text-slate-300" ]
           ].each do |label, value, color| %>
          <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 p-4 text-center">
            <p class="text-2xl font-bold <%= color %>"><%= value %></p>
            <p class="mt-1 text-xs uppercase tracking-wide text-slate-400"><%= label %></p>
          </div>
        <% end %>
      </div>

      <% if q[:recent].any? %>
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900">
          <table class="w-full text-left text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/50 text-xs uppercase tracking-wide text-slate-400">
              <tr>
                <th class="px-4 py-2 font-medium">Job</th>
                <th class="px-4 py-2 font-medium">Cola</th>
                <th class="px-4 py-2 font-medium">Estado</th>
                <th class="px-4 py-2 font-medium text-right">Creado</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
              <% q[:recent].each do |job| %>
                <tr>
                  <td class="px-4 py-2 font-mono text-xs text-slate-700 dark:text-slate-300"><%= job[:class_name] %></td>
                  <td class="px-4 py-2 text-xs text-slate-500"><%= job[:queue] %></td>
                  <td class="px-4 py-2">
                    <% color = { "finished" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-300", "failed" => "bg-red-100 text-red-700 dark:bg-red-500/15 dark:text-red-300", "scheduled" => "bg-amber-100 text-amber-700 dark:bg-amber-500/15 dark:text-amber-300", "ready" => "bg-sky-100 text-sky-700 dark:bg-sky-500/15 dark:text-sky-300" }[job[:status]] %>
                    <span class="rounded px-1.5 py-0.5 text-xs font-semibold <%= color %>"><%= job[:status] %></span>
                  </td>
                  <td class="px-4 py-2 text-right font-mono text-xs text-slate-500"><%= job[:at].strftime("%H:%M:%S") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="mt-4 rounded-xl border border-dashed border-slate-300 p-6 text-center text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
          No hay jobs todavía. Pulsa <strong>“Encolar job de demo”</strong> para ver actividad.
        </p>
      <% end %>
    <% else %>
      <p class="rounded-xl border border-dashed border-slate-300 p-6 text-center text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
        Solid Queue no está disponible en este entorno.
      </p>
    <% end %>
  </section>

  <%# ---- Inventario del proceso ---- %>
  <section>
    <h2 class="mb-1 text-sm font-semibold uppercase tracking-widest text-slate-500">Inventario del proceso</h2>
    <p class="mb-3 text-xs text-slate-400">
      Identidad del proceso y almacenamiento: útil como referencia, no como señal de salud.
    </p>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-5">
      <% inventory = {
           "Rails" => metrics[:app][:rails],
           "Ruby" => metrics[:app][:ruby],
           "Entorno" => metrics[:app][:env],
           "PID" => metrics[:app][:pid],
           "Uptime" => metrics[:app][:uptime]
         } %>
      <% metrics[:databases].each do |db| %>
        <% inventory["BD #{db[:name]}"] = number_to_human_size(db[:size]) %>
      <% end %>
      <% inventory["Solid Cache"] = metrics[:cache][:available] ? "#{metrics[:cache][:entries]} entradas" : "n/d" %>
      <% inventory.each do |label, value| %>
        <div class="rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900 px-3 py-2.5">
          <p class="text-[10px] uppercase tracking-wide text-slate-400"><%= label %></p>
          <p class="mt-0.5 truncate font-mono text-xs font-semibold text-slate-700 dark:text-slate-300" title="<%= value %>"><%= value %></p>
        </div>
      <% end %>
    </div>
  </section>
</div>
