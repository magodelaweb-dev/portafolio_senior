<div class="space-y-8">
  <div class="flex items-center justify-between text-xs text-slate-400">
    <span class="inline-flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      Monitoreando
    </span>
    <span>Actualizado a las <%= metrics[:generated_at].strftime("%H:%M:%S") %></span>
  </div>

  <%# ---- Aplicación ---- %>
  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">Aplicación</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-5">
      <% {
           "Rails" => metrics[:app][:rails],
           "Ruby" => metrics[:app][:ruby],
           "Entorno" => metrics[:app][:env],
           "PID" => metrics[:app][:pid],
           "Uptime" => metrics[:app][:uptime]
         }.each do |label, value| %>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wide text-slate-400"><%= label %></p>
          <p class="mt-1 font-mono text-sm font-semibold text-slate-800"><%= value %></p>
        </div>
      <% end %>
    </div>
  </section>

  <%# ---- Telemetría de peticiones ---- %>
  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">Métricas de Peticiones HTTP (Muestreo en Memoria)</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-5">
      <% req = metrics[:requests] %>
      <% [
           [ "Muestras", req[:count], "" ],
           [ "Media", req[:avg], " ms" ],
           [ "p95", req[:p95], " ms" ],
           [ "Máx", req[:max], " ms" ],
           [ "BD (Promedio)", req[:avg_db], " ms" ]
         ].each do |label, value, unit| %>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wide text-slate-400"><%= label %></p>
          <p class="mt-1 text-2xl font-bold text-slate-900"><%= value %><span class="text-sm font-normal text-slate-400"><%= unit %></span></p>
        </div>
      <% end %>
    </div>

    <% if req[:recent].any? %>
      <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-400">
            <tr>
              <th class="px-4 py-2 font-medium">Endpoint</th>
              <th class="px-4 py-2 font-medium">Estado</th>
              <th class="px-4 py-2 font-medium text-right">Duración</th>
              <th class="px-4 py-2 font-medium text-right">BD</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% req[:recent].each do |s| %>
              <tr>
                <td class="px-4 py-2 font-mono text-xs text-slate-700"><%= s.controller %>#<%= s.action %></td>
                <td class="px-4 py-2">
                  <span class="rounded px-1.5 py-0.5 text-xs font-semibold <%= s.status.to_i < 400 ? "bg-emerald-100 text-emerald-700" : "bg-red-100 text-red-700" %>"><%= s.status %></span>
                </td>
                <td class="px-4 py-2 text-right font-mono text-xs text-slate-700"><%= s.duration %> ms</td>
                <td class="px-4 py-2 text-right font-mono text-xs text-slate-500"><%= s.db_runtime %> ms</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>

  <%# ---- Bases de datos SQLite ---- %>
  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">Bases de datos SQLite</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
      <% metrics[:databases].each do |db| %>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <p class="text-xs uppercase tracking-wide text-slate-400"><%= db[:name] %></p>
          <p class="mt-1 text-lg font-bold text-slate-900"><%= number_to_human_size(db[:size]) %></p>
          <p class="mt-1 truncate font-mono text-xs text-slate-400" title="<%= db[:path] %>"><%= db[:path] %></p>
        </div>
      <% end %>
    </div>
  </section>

  <%# ---- Solid Queue ---- %>
  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">Solid Queue</h2>
    <% q = metrics[:queue] %>
    <% if q[:available] %>
      <div class="grid grid-cols-3 gap-4 sm:grid-cols-6">
        <% [
             [ "Listos", q[:ready], "text-sky-700" ],
             [ "Programados", q[:scheduled], "text-amber-700" ],
             [ "En curso", q[:in_progress], "text-indigo-700" ],
             [ "Fallidos", q[:failed], "text-red-700" ],
             [ "Finalizados", q[:finished], "text-emerald-700" ],
             [ "Procesos", q[:processes], "text-slate-700" ]
           ].each do |label, value, color| %>
          <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
            <p class="text-2xl font-bold <%= color %>"><%= value %></p>
            <p class="mt-1 text-xs uppercase tracking-wide text-slate-400"><%= label %></p>
          </div>
        <% end %>
      </div>

      <% if q[:recent].any? %>
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white">
          <table class="w-full text-left text-sm">
            <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-400">
              <tr>
                <th class="px-4 py-2 font-medium">Job</th>
                <th class="px-4 py-2 font-medium">Cola</th>
                <th class="px-4 py-2 font-medium">Estado</th>
                <th class="px-4 py-2 font-medium text-right">Creado</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% q[:recent].each do |job| %>
                <tr>
                  <td class="px-4 py-2 font-mono text-xs text-slate-700"><%= job[:class_name] %></td>
                  <td class="px-4 py-2 text-xs text-slate-500"><%= job[:queue] %></td>
                  <td class="px-4 py-2">
                    <% color = { "finished" => "bg-emerald-100 text-emerald-700", "failed" => "bg-red-100 text-red-700", "scheduled" => "bg-amber-100 text-amber-700", "ready" => "bg-sky-100 text-sky-700" }[job[:status]] %>
                    <span class="rounded px-1.5 py-0.5 text-xs font-semibold <%= color %>"><%= job[:status] %></span>
                  </td>
                  <td class="px-4 py-2 text-right font-mono text-xs text-slate-500"><%= job[:at].strftime("%H:%M:%S") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="mt-4 rounded-xl border border-dashed border-slate-300 p-6 text-center text-sm text-slate-500">
          No hay jobs todavía. Pulsa <strong>“Encolar job de demo”</strong> para ver actividad.
        </p>
      <% end %>
    <% else %>
      <p class="rounded-xl border border-dashed border-slate-300 p-6 text-center text-sm text-slate-500">
        Solid Queue no está disponible en este entorno.
      </p>
    <% end %>
  </section>

  <%# ---- Solid Cache ---- %>
  <section>
    <h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-slate-500">Solid Cache</h2>
    <% c = metrics[:cache] %>
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <% if c[:available] %>
        <p class="text-xs uppercase tracking-wide text-slate-400">Elementos en Caché</p>
        <p class="mt-1 text-2xl font-bold text-slate-900"><%= c[:entries] %></p>
      <% else %>
        <p class="text-sm text-slate-500">Solid Cache no está disponible en este entorno.</p>
      <% end %>
    </div>
  </section>
</div>
