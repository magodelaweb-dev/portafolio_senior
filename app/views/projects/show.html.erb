<% content_for :title, "#{@project.title} · Arturo Martinez" %>
<% content_for :meta_description, @project.subtitle if @project.subtitle.present? %>

<div class="mx-auto max-w-3xl">
  <% if notice.present? %>
    <p class="mb-6 inline-block rounded-md bg-emerald-50 px-3 py-2 font-medium text-emerald-600" id="notice"><%= notice %></p>
  <% end %>

  <%= link_to root_path, class: "mb-8 inline-flex items-center gap-1 text-sm font-medium text-slate-500 transition hover:text-indigo-600" do %>
    <span aria-hidden="true">&larr;</span> Volver a proyectos
  <% end %>

  <%= render @project %>

  <% if authenticated? %>
    <div class="mt-16 flex flex-wrap items-center gap-3 border-t border-slate-200 pt-6 text-sm text-slate-400">
      <span class="font-medium uppercase tracking-widest">Administrar</span>
      <%= link_to "Editar", edit_project_path(@project), class: "rounded-md px-3 py-1.5 text-slate-600 transition hover:bg-slate-100" %>
      <%= button_to "Eliminar", @project, method: :delete, class: "rounded-md px-3 py-1.5 text-red-600 transition hover:bg-red-50 cursor-pointer", form_class: "inline-block", data: { turbo_confirm: "¿Seguro que quieres eliminar este proyecto?" } %>
    </div>
  <% end %>
</div>
