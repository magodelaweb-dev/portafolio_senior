<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Arturo Martinez · Ingeniero de Software Senior" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Portafolio Senior">
    <meta name="mobile-web-app-capable" content="yes">

    <% meta_description = content_for(:meta_description) ||
         "Portafolio de Arturo Martinez, ingeniero de software senior: estudios de caso de arquitectura (FinTech, IoT, SaaS multi-tenant) con metodología STAR, trade-offs de ingeniería y un panel de observabilidad en vivo de la propia aplicación." %>
    <meta name="description" content="<%= meta_description %>">
    <meta property="og:site_name" content="Arturo Martinez · Portafolio">
    <meta property="og:title" content="<%= content_for(:title) || "Arturo Martinez · Ingeniero de Software Senior" %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="es_ES">
    <meta property="og:image" content="<%= "#{request.base_url}/icon.png" %>">
    <meta name="twitter:card" content="summary">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <%= link_to root_path, class: "flex items-center gap-2 font-semibold tracking-tight" do %>
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-indigo-600 text-sm font-bold text-white">AM</span>
          <span>Arturo Martinez</span>
        <% end %>
        <div class="flex items-center gap-6 text-sm font-medium text-slate-600">
          <%= link_to "Proyectos", root_path, class: "transition hover:text-indigo-600" %>
          <%= link_to "Sobre mí", about_path, class: "transition hover:text-indigo-600" %>
          <%= link_to "Operaciones", ops_path, class: "transition hover:text-indigo-600" %>
          <a href="https://github.com/magodelaweb-dev/portafolio_senior" class="transition hover:text-indigo-600">Código del sitio</a>
          <% if authenticated? %>
            <%= button_to "Salir", session_path, method: :delete, class: "cursor-pointer font-medium text-slate-600 transition hover:text-indigo-600" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-12">
      <%= yield %>
    </main>

    <footer class="border-t border-slate-200 py-8">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-5 text-sm text-slate-500">
        <span>&copy; <%= Date.current.year %> Arturo Martinez &middot; Construido con Rails <%= Rails::VERSION::STRING %> y Tailwind CSS</span>
        <span class="flex items-center gap-5 font-medium text-slate-600">
          <a href="<%= contact_linkedin_url %>" target="_blank" rel="noopener" class="transition hover:text-indigo-600">LinkedIn</a>
          <a href="mailto:<%= contact_email %>" class="transition hover:text-indigo-600">Email</a>
          <a href="<%= contact_cv_path %>" download class="transition hover:text-indigo-600">CV</a>
        </span>
      </div>
    </footer>
  </body>
</html>
