<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Arturo Martinez · Ingeniero de Software Senior" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Portafolio Senior">
    <meta name="mobile-web-app-capable" content="yes">

    <% meta_description = content_for(:meta_description) ||
         "Portafolio de Arturo Martinez, ingeniero de software senior: estudios de caso de arquitectura (FinTech, IoT, SaaS multi-tenant) con metodología STAR, trade-offs de ingeniería y un panel de observabilidad en vivo de la propia aplicación." %>
    <meta name="description" content="<%= meta_description %>">
    <meta property="og:site_name" content="Arturo Martinez · Portafolio">
    <meta property="og:title" content="<%= content_for(:title) || "Arturo Martinez · Ingeniero de Software Senior" %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="es_ES">
    <meta property="og:image" content="<%= "#{request.base_url}/icon.png" %>">
    <meta name="twitter:card" content="summary">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased dark:bg-slate-950 dark:text-slate-100">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
      <nav class="mx-auto max-w-5xl px-5"
           data-controller="nav"
           data-action="turbo:load@window->nav#closeOnNavigation resize@window->nav#closeOnResize">
        <div class="flex items-center justify-between py-4">
          <%= link_to root_path, class: "flex items-center gap-2 font-semibold tracking-tight" do %>
            <span class="grid h-8 w-8 place-items-center rounded-lg bg-teal-600 text-sm font-bold text-white">AM</span>
            <span>Arturo Martinez</span>
          <% end %>

          <div class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex dark:text-slate-300">
            <%= render "layouts/nav_links" %>
          </div>

          <button type="button"
                  data-nav-target="trigger"
                  data-action="nav#toggle"
                  aria-controls="mobile-nav"
                  aria-expanded="false"
                  aria-label="Abrir menú de navegación"
                  class="-mr-2 inline-flex cursor-pointer items-center justify-center rounded-lg p-2 text-slate-600 transition hover:bg-slate-100 hover:text-teal-600 md:hidden dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-teal-400">
            <svg data-nav-target="openIcon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
            </svg>
            <svg data-nav-target="closeIcon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <div id="mobile-nav" data-nav-target="panel" class="hidden border-t border-slate-200 pb-4 md:hidden dark:border-slate-800">
          <div class="flex flex-col gap-1 pt-2 text-base font-medium text-slate-600 dark:text-slate-300">
            <%= render "layouts/nav_links", mobile: true %>
          </div>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-5 py-12">
      <%= yield %>
    </main>

    <footer class="border-t border-slate-200 py-8 dark:border-slate-800">
      <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-5 text-sm text-slate-500 dark:text-slate-400">
        <span>&copy; <%= Date.current.year %> Arturo Martinez &middot; Construido con Rails <%= Rails::VERSION::STRING %> y Tailwind CSS</span>
        <span class="flex items-center gap-5 font-medium text-slate-600 dark:text-slate-300">
          <a href="<%= contact_linkedin_url %>" target="_blank" rel="noopener" class="transition hover:text-teal-600 dark:hover:text-teal-400">LinkedIn</a>
          <a href="mailto:<%= contact_email %>" class="transition hover:text-teal-600 dark:hover:text-teal-400">Email</a>
          <a href="<%= contact_cv_path %>" download class="transition hover:text-teal-600 dark:hover:text-teal-400">CV</a>
        </span>
      </div>
    </footer>
  </body>
</html>
